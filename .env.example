# 复制为 .env 并填写（.env 已 gitignore，密钥不进 commit）

# GitHub PAT：头像 → Settings → Developer settings → Personal access tokens
# → Tokens (classic) → Generate new token，scope 一个都不勾（只读公开数据）
GITHUB_TOKEN=

# Firecrawl 二选一：
# A. 自部署（推荐，CI 上自动临时启动）：本地用 docker 跑 firecrawl 后填地址
#FIRECRAWL_API_URL=http://localhost:3002
# B. 云端 key（本地快速验证用，免费 500 credits）：https://www.firecrawl.dev/app/api-keys
#FIRECRAWL_API_KEY=
